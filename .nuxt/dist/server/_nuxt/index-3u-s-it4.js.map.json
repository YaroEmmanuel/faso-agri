,YAAY,MAAM,aAAkB,SAAS,SAAA;AAAA,MAChF,EAAE,OAAO,mBAAmB,OAAO,YAAY,MAAM,kBAAkB,SAAS,QAAA;AAAA,IAAoB,CACrG;AAED,UAAM,gBAAgB,IAAI,KAAK;AAC/B,UAAM,cAAgB,IAAW,EAAE;AAEnC,UAAM,aAA4E;AAAA,MAChF,MAAc,EAAE,OAAO,aAAa,OAAO,4BAA8B,KAAK,cAAA;AAAA,MAC9E,QAAc,EAAE,OAAO,WAAa,OAAO,8BAA8B,KAAK,eAAA;AAAA,MAC9E,OAAc,EAAE,OAAO,UAAa,OAAO,0BAA8B,KAAK,aAAA;AAAA,MAC9E,cAAc,EAAE,OAAO,WAAa,OAAO,8BAA8B,KAAK,eAAA;AAAA,IAAe;AAG/F,aAAS,WAAW,MAAc;AAAE,aAAO,WAAW,IAAI,GAAG,SAAS;AAAA,IAA4B;AAClG,aAAS,SAAS,MAAgB;AAAE,aAAO,WAAW,IAAI,GAAG,OAAS;AAAA,IAAc;;;;;;yBA/FlF,CAiEc,GAAAC,QAAAC,UAAA,aAAA;;;AArDSC,0BAAAH,MAAA,KAAA,IAAR,SAAI;;gBACV,KAAK,KAAK;AAAA,gBACV,OAAO,KAAK;AAAA,gBACZ,OAAO,KAAK;AAAA,gBACZ,YAAU,KAAK;AAAA,gBACf,SAASA,MAAA,YAAA;AAAA,cAAA;;;;cAYR,IAAG;AAAA,cACH,OAAM;AAAA,YAAA;+BAFR,CAKWI,IAAAH,QAAAC,UAAAG,cAAA;;;;;oCAFV,aAED;AAAA,kBAAA;AAAA;;;;;gBAGSL,MAAA,aAAA,GAAa;;AACLG,4BAAA,IAAL,MAAC;;;;;;AAUIA,4BAAAH,MAAA,WAAA,IAAR,SAAI;+IAIE,SAAS,KAAK,IAAI,GAAA,oCAAA,CAAA,+FACiCM,eAAA,KAAK,KAAK,qFACLA,eAAA,KAAK,IAAI,wCAChE,WAAW,KAAK,IAAI,GAAA,4DAAA,CAAA,iBAC7BA,eAAA,KAAK,SAAS;;;AAGV,kBAAAN,MAAA,WAAA,EAAY,WAAM,GAAA;;;;;;;;;;cAzDnCO,YA+DM,OAAA,EA/DD,OAAM,eAAW;AAAA,gBAGpBA,YAGM,OAAA,MAAA;AAAA,kBAFJA,YAAgE,MAAA,EAA5D,OAAM,kCAAA,GAAkC,iBAAe;AAAA,kBAC3DA,YAAqF,KAAA,EAAlF,OAAM,+BAAA,GAA+B,2CAAyC;AAAA,gBAAA;gBAInFA,YASM,OAAA,EATD,OAAM,2CAAuC;AAAA,oCAChDC,YAOEC,UAAA,MAAAC,WANeV,MAAA,KAAA,GAAK,CAAb,SAAI;wCADbQ,YAOE,0BAAA;AAAA,sBALC,KAAK,KAAK;AAAA,sBACV,OAAO,KAAK;AAAA,sBACZ,OAAO,KAAK;AAAA,sBACZ,YAAU,KAAK;AAAA,sBACf,SAASR,MAAA,YAAA;AAAA,oBAAA;;;gBAKdO,YAwCM,OAAA,EAxCD,OAAM,iEAA6D;AAAA,kBACtEA,YAWM,OAAA,EAXD,OAAM,0EAAsE;AAAA,oBAC/EA,YAGM,OAAA,MAAA;AAAA,sBAFJA,YAA2E,MAAA,EAAvE,OAAM,sCAAA,GAAsC,wBAAsB;AAAA,sBACtEA,YAAoF,KAAA,EAAjF,OAAM,+BAAA,GAA+B,0CAAwC;AAAA,oBAAA;oBAElFA,YAKW,qBAAA;AAAA,sBAJT,IAAG;AAAA,sBACH,OAAM;AAAA,oBAAA;uCACP,MAED;AAAA,wCAFC,aAED;AAAA,sBAAA;;;;kBAGSP,MAAA,aAAA,kBAAXQ,YAOM,OAAA;AAAA;oBAPoB,OAAM;AAAA,kBAAA;kCAC9BA,YAKMC,UAAA,MAAAC,WALW,GAAC,CAAN,MAAC;6BAAbH,YAKM,OAAA;AAAA,wBALe,KAAK;AAAA,wBAAG,OAAM;AAAA,sBAAA;wBACjCA,YAA8D,OAAA,EAAzD,OAAM,kDAAgD;AAAA,wBAC3DA,YAA4D,OAAA,EAAvD,OAAM,gDAA8C;AAAA,wBACzDA,YAA0D,OAAA,EAArD,OAAM,8CAA4C;AAAA,wBACvDA,YAA+D,OAAA,EAA1D,OAAM,mDAAiD;AAAA,sBAAA;;sCAIhEC,YAgBM,OAAA;AAAA;oBAhBM,OAAM;AAAA,kBAAA;sCAChBA,YAWMC,UAAA,MAAAC,WAVWV,MAAA,WAAA,GAAW,CAAnB,SAAI;0CADbQ,YAWM,OAAA;AAAA,wBATH,KAAK,KAAK;AAAA,wBACX,OAAM;AAAA,sBAAA;wBAEND,YAA+E,OAAA;AAAA,0BAAzE,QAAO,SAAS,KAAK,IAAI,GAAS,oCAAoC;AAAA,wBAAA;wBAC5EA,YAAiF,OAA9E,OAAM,oDAAA,GAAmDI,gBAAI,KAAK,KAAK,GAAA,CAAA;AAAA,wBAC1EJ,YAAwF,UAAlF,OAAM,sDAAA,GAAqDI,gBAAI,KAAK,IAAI,GAAA,CAAA;AAAA,wBAC9EJ,YAEO,QAAA;AAAA,0BAFA,QAAO,WAAW,KAAK,IAAI,GAAS,4DAA4D;AAAA,wBAAA,GAClGI,gBAAA,KAAK,SAAS,GAAA,CAAA;AAAA,sBAAA;;oBAGVX,MAAA,WAAA,EAAY,WAAM,kBAA7BQ,YAEM,OAAA;AAAA;sBAF+B,OAAM;AAAA,oBAAA,GAA+C,sCAE1F;;;;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_unref","_push","_parent","_ssrRenderList","_","_scopeId","_ssrInterpolate","_createVNode","_createBlock","_Fragment","_renderList","_toDisplayString"],"sources":["../../../../components/admin/AdminStatCard.vue","../../../../pages/admin/index.vue"],"sourcesContent":["<template>\n  <div class=\"bg-white rounded-2xl border border-gray-100 p-5 flex flex-col gap-4\">\n    <div v-if=\"loading\" class=\"space-y-3\">\n      <div class=\"h-3 w-20 bg-gray-100 rounded-full animate-pulse\" />\n      <div class=\"h-8 w-24 bg-gray-100 rounded-full animate-pulse\" />\n    </div>\n    <template v-else>\n      <div class=\"flex items-center justify-between\">\n        <p class=\"text-xs font-medium text-gray-400 uppercase tracking-widest\">{{ label }}</p>\n        <div :class=\"iconBg\" class=\"w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0\">\n          <component :is=\"svgIcon\" :class=\"iconColor\" class=\"w-[18px] h-[18px]\" />\n        </div>\n      </div>\n      <div>\n        <p class=\"text-3xl font-bold text-gray-900 tracking-tight\">{{ formattedValue }}</p>\n      </div>\n    </template>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { defineComponent, h } from 'vue'\n\nconst props = defineProps<{\n  label: string\n  value: number\n  iconKey: 'users' | 'products' | 'events' | 'forum'\n  loading?: boolean\n}>()\n\n// SVG icons by key\nconst icons = {\n  users: defineComponent({ render: () => h('svg', { fill: 'none', stroke: 'currentColor', viewBox: '0 0 24 24' }, [\n    h('path', { 'stroke-linecap': 'round', 'stroke-linejoin': 'round', 'stroke-width': '1.75',\n      d: 'M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75' })\n  ])}),\n  products: defineComponent({ render: () => h('svg', { fill: 'none', stroke: 'currentColor', viewBox: '0 0 24 24' }, [\n    h('path', { 'stroke-linecap': 'round', 'stroke-linejoin': 'round', 'stroke-width': '1.75',\n      d: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2 9m12-9l2 9M9 21a1 1 0 100-2 1 1 0 000 2zm10 0a1 1 0 100-2 1 1 0 000 2z' })\n  ])}),\n  events: defineComponent({ render: () => h('svg', { fill: 'none', stroke: 'currentColor', viewBox: '0 0 24 24' }, [\n    h('path', { 'stroke-linecap': 'round', 'stroke-linejoin': 'round', 'stroke-width': '1.75',\n      d: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' })\n  ])}),\n  forum: defineComponent({ render: () => h('svg', { fill: 'none', stroke: 'currentColor', viewBox: '0 0 24 24' }, [\n    h('path', { 'stroke-linecap': 'round', 'stroke-linejoin': 'round', 'stroke-width': '1.75',\n      d: 'M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z' })\n  ])}),\n}\n\nconst palette = {\n  users:    { bg: 'bg-blue-50',   color: 'text-blue-600' },\n  products: { bg: 'bg-green-50',  color: 'text-green-700' },\n  events:   { bg: 'bg-amber-50',  color: 'text-amber-600' },\n  forum:    { bg: 'bg-violet-50', color: 'text-violet-600' },\n}\n\nconst svgIcon  = computed(() => icons[props.iconKey])\nconst iconBg   = computed(() => palette[props.iconKey].bg)\nconst iconColor = computed(() => palette[props.iconKey].color)\n\nconst formattedValue = computed(() =>\n  props.value >= 1000\n    ? (props.value / 1000).toFixed(1) + 'k'\n    : String(props.value)\n)\n</script>\n","<template>\n  <AdminLayout>\n    <div class=\"space-y-7\">\n\n      <!-- Header -->\n      <div>\n        <h1 class=\"text-xl font-bold text-gray-900\">Tableau de bord</h1>\n        <p class=\"text-sm text-gray-400 mt-0.5\">Vue d'ensemble de la plateforme Faso Agri</p>\n      </div>\n\n      <!-- Stat Cards -->\n      <div class=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">\n        <AdminStatCard\n          v-for=\"stat in stats\"\n          :key=\"stat.label\"\n          :label=\"stat.label\"\n          :value=\"stat.value\"\n          :icon-key=\"stat.iconKey\"\n          :loading=\"statsLoading\"\n        />\n      </div>\n\n      <!-- Recent publications table -->\n      <div class=\"bg-white rounded-2xl border border-gray-100 overflow-hidden\">\n        <div class=\"px-6 py-4 border-b border-gray-100 flex items-center justify-between\">\n          <div>\n            <h2 class=\"text-sm font-semibold text-gray-900\">Dernières publications</h2>\n            <p class=\"text-xs text-gray-400 mt-0.5\">5 publications récentes de la plateforme</p>\n          </div>\n          <NuxtLink\n            to=\"/admin/publications\"\n            class=\"text-xs font-medium text-primary hover:underline underline-offset-2 transition\"\n          >\n            Voir tout\n          </NuxtLink>\n        </div>\n\n        <div v-if=\"recentLoading\" class=\"divide-y divide-gray-50\">\n          <div v-for=\"i in 5\" :key=\"i\" class=\"px-6 py-4 flex items-center gap-4\">\n            <div class=\"h-3 w-3 rounded-full bg-gray-100 animate-pulse\" />\n            <div class=\"flex-1 h-3 bg-gray-100 rounded animate-pulse\" />\n            <div class=\"h-3 w-16 bg-gray-100 rounded animate-pulse\" />\n            <div class=\"h-5 w-20 bg-gray-100 rounded-full animate-pulse\" />\n          </div>\n        </div>\n\n        <div v-else class=\"divide-y divide-gray-50\">\n          <div\n            v-for=\"item in recentItems\"\n            :key=\"item.id\"\n            class=\"px-6 py-4 flex items-center gap-4 hover:bg-gray-50/60 transition\"\n          >\n            <div :class=\"dotClass(item.type)\" class=\"w-2 h-2 rounded-full flex-shrink-0\" />\n            <p class=\"flex-1 text-sm text-gray-700 font-medium truncate\">{{ item.title }}</p>\n            <span class=\"text-xs text-gray-400 flex-shrink-0 hidden sm:block\">{{ item.date }}</span>\n            <span :class=\"badgeClass(item.type)\" class=\"text-xs font-medium px-2.5 py-1 rounded-full flex-shrink-0\">\n              {{ item.typeLabel }}\n            </span>\n          </div>\n          <div v-if=\"recentItems.length === 0\" class=\"px-6 py-10 text-center text-sm text-gray-400\">\n            Aucune publication pour le moment.\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </AdminLayout>\n</template>\n\n<script setup lang=\"ts\">\nconst { $firestore } = useNuxtApp()\n\ndefinePageMeta({ middleware: 'admin' })\nuseSeoMeta({ title: 'Tableau de bord — Admin Faso Agri' })\n\nconst statsLoading = ref(false)\nconst globalStats  = ref({ totalUsers: 0, totalProducts: 0, totalEvents: 0, totalForumTopics: 0 })\n\nconst stats = computed(() => [\n  { label: 'Utilisateurs',    value: globalStats.value.totalUsers,       iconKey: 'users'    as const },\n  { label: 'Produits',        value: globalStats.value.totalProducts,    iconKey: 'products' as const },\n  { label: 'Événements',      value: globalStats.value.totalEvents,      iconKey: 'events'   as const },\n  { label: 'Sujets du forum', value: globalStats.value.totalForumTopics, iconKey: 'forum'    as const },\n])\n\nconst recentLoading = ref(false)\nconst recentItems   = ref<any[]>([])\n\nconst typeConfig: Record<string, { label: string; badge: string; dot: string }> = {\n  news:         { label: 'Actualité', badge: 'bg-blue-50 text-blue-700',   dot: 'bg-blue-400' },\n  advice:       { label: 'Conseil',   badge: 'bg-amber-50 text-amber-700', dot: 'bg-amber-400' },\n  alert:        { label: 'Alerte',    badge: 'bg-red-50 text-red-600',     dot: 'bg-red-400' },\n  announcement: { label: 'Annonce',   badge: 'bg-green-50 text-green-700', dot: 'bg-green-400' },\n}\n\nfunction badgeClass(type: string) { return typeConfig[type]?.badge ?? 'bg-gray-100 text-gray-500' }\nfunction dotClass(type: string)   { return typeConfig[type]?.dot   ?? 'bg-gray-300' }\n\nconst fallbackStats = { totalUsers: 142, totalProducts: 87, totalEvents: 23, totalForumTopics: 56 }\nconst fallbackItems = [\n  { id: '1', title: 'Récolte de mil en région du Sahel',                  type: 'news',         typeLabel: 'Actualité', date: '5 mai 2026' },\n  { id: '2', title: 'Techniques d\\'irrigation goutte-à-goutte',           type: 'advice',       typeLabel: 'Conseil',   date: '4 mai 2026' },\n  { id: '3', title: 'Alerte criquet pèlerin — Nord du Burkina',           type: 'alert',        typeLabel: 'Alerte',    date: '3 mai 2026' },\n  { id: '4', title: 'Vente groupée haricots verts — Bobo-Dioulasso',      type: 'announcement', typeLabel: 'Annonce',   date: '2 mai 2026' },\n  { id: '5', title: 'Formation agropastorale — Koudougou',                type: 'news',         typeLabel: 'Actualité', date: '1 mai 2026' },\n]\n\nonMounted(async () => {\n  if (!$firestore) {\n    globalStats.value = fallbackStats\n    recentItems.value = fallbackItems\n    return\n  }\n  try {\n    const { doc, getDoc, collection, query, orderBy, limit, getDocs } = await import('firebase/firestore')\n    const fs = $firestore as any\n\n    statsLoading.value  = true\n    recentLoading.value = true\n\n    const snap = await getDoc(doc(fs, 'stats', 'global'))\n    if (snap.exists()) globalStats.value = snap.data() as any\n    statsLoading.value = false\n\n    const pubQ    = query(collection(fs, 'publications'), orderBy('createdAt', 'desc'), limit(5))\n    const pubSnap = await getDocs(pubQ)\n    recentItems.value = pubSnap.docs.map(d => {\n      const data = d.data()\n      const cfg  = typeConfig[data.type] ?? { label: data.type, badge: '', dot: '' }\n      return {\n        id: d.id, title: data.title, type: data.type, typeLabel: cfg.label,\n        date: data.createdAt?.toDate().toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }) ?? '—',\n      }\n    })\n    recentLoading.value = false\n  } catch (e) {\n    console.error(e)\n    statsLoading.value  = false\n    recentLoading.value = false\n    globalStats.value = fallbackStats\n    recentItems.value = fallbackItems\n  }\n})\n</script>\n"],"version":3}